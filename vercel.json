{
  "functions": {
    "app/api/flyer/generate/route.ts": { "maxDuration": 30 },
    "app/api/scrape/route.ts": { "maxDuration": 30 },
    "app/api/ai/route.ts": { "maxDuration": 30 },
    "app/api/scan/route.ts": { "maxDuration": 30 },
    "app/api/cron/dispatch/route.ts": { "maxDuration": 300 },
    "app/api/cron/follow-up/route.ts": { "maxDuration": 60 },
    "app/api/cron/monthly-report/route.ts": { "maxDuration": 120 }
  },
  "crons": [
    {
      "path": "/api/cron/dispatch",
      "schedule": "0 8 25 * *"
    },
    {
      "path": "/api/cron/follow-up",
