# ── LokaalKabaal Environment Variables ──────────────────────────────────────
# Kopieer naar .env.local en vul in

# App URL (Vercel deployment URL)
NEXT_PUBLIC_APP_URL=https://lokaalkabaal.vercel.app

# Neon Postgres database
DATABASE_URL=postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Anthropic Claude AI (flyer tekst generatie)
ANTHROPIC_API_KEY=sk-ant-...

# Stripe (betalingen)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Print.one (flyer drukwerk + verzending)
PRINTONE_API_KEY=

# Altum.ai (woningoverdrachten data)
ALTUM_API_KEY=

# Browserless (website screenshots voor flyer)
BROWSERLESS_TOKEN=

# Cron autorisatie (willekeurige string)
CRON_SECRET=
