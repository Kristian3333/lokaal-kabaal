# Lokaalkabaal Environment Variables
# Copy this file to .env.local and fill in the values
# NEVER commit .env.local to git

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname

# Authentication
SESSION_SECRET=generate-a-random-string-here

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# PrintOne (printing service)
PRINTONE_API_KEY=test_...
PRINTONE_WEBHOOK_SECRET=

# Anthropic (AI flyer generation)
ANTHROPIC_API_KEY=sk-ant-...

# Resend (email)
RESEND_API_KEY=re_...

# Vercel Blob Storage
BLOB_READ_WRITE_TOKEN=vercel_blob_...

# Browserless (PDF generation)
BROWSERLESS_TOKEN=

# Altum API (address/transaction data)
ALTUM_API_KEY=

# Cron job verification
CRON_SECRET=generate-a-random-string-here

# Redeem code API
REDEEM_API_KEY=generate-a-random-string-here

# Admin
ADMIN_EMAILS=email@example.com

# Public URLs (accessible on client side)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_URL=http://localhost:3000
