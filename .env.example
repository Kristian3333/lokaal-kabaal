# ============================================================================
# LokaalKabaal - Environment Variables
# Copy this file to .env.local and fill in the values.
# ============================================================================

# --- DATABASE (required) ---
# Sign up: https://neon.tech (free tier available)
# Create a project, copy the connection string from the dashboard.
DATABASE_URL=postgresql://user:password@ep-xxx.region.neon.tech/neondb?sslmode=require

# --- AUTHENTICATION (required) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=

# --- STRIPE (required for payments) ---
# Sign up: https://dashboard.stripe.com/register
# Keys at: https://dashboard.stripe.com/apikeys
# Webhook secret: https://dashboard.stripe.com/webhooks (add endpoint for /api/stripe/webhook)
# Events to listen for: checkout.session.completed, customer.subscription.updated,
#   customer.subscription.deleted, invoice.payment_failed
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- RESEND (required for emails) ---
# Sign up: https://resend.com/signup (free tier: 3,000 emails/month)
# API key at: https://resend.com/api-keys
# You must verify your sending domain at: https://resend.com/domains
# The FROM address is noreply@lokaalkabaal.agency -- verify that domain.
RESEND_API_KEY=re_...

# --- ANTHROPIC (required for AI flyer generation) ---
# Sign up: https://console.anthropic.com
# API key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# --- PRINT.ONE (required for flyer printing/delivery) ---
# Sign up: https://www.print.one (Dutch direct mail API)
# API key at: https://portal.print.one/settings/api-keys
# Webhook secret: configure at https://portal.print.one/settings/webhooks
#   (add endpoint for /api/printone/webhook)
PRINTONE_API_KEY=
PRINTONE_WEBHOOK_SECRET=

# --- VERCEL BLOB (optional -- PDF/image storage) ---
# Automatically available on Vercel deployments.
# For local dev: https://vercel.com/docs/storage/vercel-blob
BLOB_READ_WRITE_TOKEN=

# --- VERCEL CRON (required for automated dispatch) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set this same value in Vercel project settings.
# Used to authenticate cron job requests:
#   /api/cron/dispatch       (25th monthly -- sends flyers)
#   /api/cron/follow-up      (daily -- scan notifications)
#   /api/cron/monthly-report (1st monthly -- performance reports)
CRON_SECRET=

# --- ALTUM AI (optional -- real property transfer data) ---
# Sign up: https://altum.ai (Dutch property data API)
# Without this key, the system uses stub/demo data for new resident addresses.
ALTUM_API_KEY=

# --- BROWSERLESS (optional -- server-side PDF rendering) ---
# Sign up: https://www.browserless.io (free tier available)
# Used for high-quality flyer PDF generation.
BROWSERLESS_TOKEN=

# --- APP URLs ---
# Your deployed URL. Used for magic links, QR codes, Stripe redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- ADMIN ---
# Comma-separated list of email addresses that can perform admin actions
# (e.g., manual credit adjustments via POST /api/stripe/credit)
ADMIN_EMAILS=your@email.com

# --- CODE REDEMPTION (required for webshop integrations) ---
# Separate API key for the /api/codes/redeem webhook (Shopify, WooCommerce, etc.)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
REDEEM_API_KEY=
